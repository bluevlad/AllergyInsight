# AllergyInsight 환경 변수 설정
# 이 파일을 .env로 복사하고 값을 입력하세요
# 중요: 실제 비밀번호와 시크릿 키는 절대 커밋하지 마세요!

# ============================================
# Database
# ============================================
# DB_PASSWORD와 동일한 값 사용
DATABASE_URL=postgresql://postgres:<YOUR_DB_PASSWORD>@localhost:5432/allergyinsight

# ============================================
# Google OAuth (ID 토큰 방식 - CLIENT_SECRET 불필요)
# https://console.cloud.google.com/apis/credentials
# ============================================
GOOGLE_CLIENT_ID=<YOUR_GOOGLE_CLIENT_ID>

# ============================================
# JWT 설정
# openssl rand -hex 32 명령어로 생성 권장
# ============================================
JWT_SECRET_KEY=<YOUR_JWT_SECRET_KEY>
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ============================================
# Super Admin 이메일 (콤마 구분)
# ============================================
SUPER_ADMIN_EMAILS=

# ============================================
# PubMed API (선택사항 - 없어도 동작하지만 요청 제한이 있음)
# https://www.ncbi.nlm.nih.gov/account/settings/ 에서 발급
# ============================================
PUBMED_API_KEY=
PUBMED_EMAIL=your-email@example.com

# ============================================
# Semantic Scholar API (선택사항 - 없어도 동작함)
# https://www.semanticscholar.org/product/api 에서 발급
# ============================================
SEMANTIC_SCHOLAR_API_KEY=

# ============================================
# OpenAI API (향후 AI 요약 기능용)
# ============================================
OPENAI_API_KEY=

# ============================================
# 네이버 뉴스 검색 API (경쟁사 뉴스 모니터링용)
# https://developers.naver.com/apps/ 에서 발급
# ============================================
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ============================================
# 약물 정보 수집 — 학술 전용 알러지 치료 Agent (drug_ingest)
# ============================================
# 공공데이터포털 서비스키 (https://www.data.go.kr)
# 1개 키로 e약은요(15075057), 제품허가정보(15095677), 건강기능식품(15100018) 공통 사용
# 참고: services/allergyinsight/plans/academic-drug-agent-plan.md Phase 1
MFDS_API_KEY=

# openFDA 키 (선택사항 — 키 없이 240/min·1000/day 가능)
# https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY=

# ============================================
# 다운로드 설정
# ============================================
DOWNLOAD_DIR=./downloads/papers

# ============================================
# 검색 설정
# ============================================
DEFAULT_MAX_RESULTS=20
SEARCH_TIMEOUT=30
